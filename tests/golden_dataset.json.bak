  {
    "query": "If a term is not explicitly defined in the IFSCA Act, 2019, how should its meaning be determined according to the Act?",
    "golden_answer": "If a word or expression is not defined in the IFSCA Act, 2019, it shall have the meaning assigned to it in the specific Acts listed under column (3) of the First Schedule to the IFSCA Act.",
    "target_node_id": "702581a5-f2a7-4b49-a9a1-0b93f4a1e1c3",
