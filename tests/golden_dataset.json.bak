[
  {
    "query": "What is the minimum investment threshold required for joint investors under the IFSCA (Fund Management) Regulations, 2025?",
    "golden_answer": "When acting as joint investors, an investor and their spouse, parent, or daughter/son must collectively invest a minimum of USD 250,000.",
